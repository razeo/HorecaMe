{
  "name": "@horecame/db",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./queries": "./src/queries/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "supabase gen types typescript --local > src/types.ts",
    "db:migrate": "supabase migration up",
    "db:seed": "psql $DATABASE_URL -f supabase/seed.sql"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0"
  },
  "devDependencies": {
    "@horecame/tsconfig": "workspace:*",
    "@horecame/shared": "workspace:*",
    "typescript": "^5.7.0"
  }
}
